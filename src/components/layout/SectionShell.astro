---
interface Props {
  id: string
  eyebrow: string
  title: string
  lead: string
}

const { id, eyebrow, title, lead } = Astro.props
---

<section id={id} class="scroll-mt-28 border-t border-[var(--border-soft)] px-4 py-16 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-6xl">
    <div class="mb-10 max-w-2xl space-y-4">
      <p class="eyebrow-token">{eyebrow}</p>
      <h2 class="text-3xl font-semibold tracking-tight text-[var(--foreground)] sm:text-4xl">{title}</h2>
      <p class="text-base leading-7 text-[var(--muted)] sm:text-lg">{lead}</p>
    </div>
    <slot />
  </div>
</section>
