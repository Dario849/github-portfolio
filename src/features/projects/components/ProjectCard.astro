---
import type { ProjectItem } from '@/features/portfolio/content'

interface Props {
  project: ProjectItem
  compact?: boolean
}

const { project, compact = false } = Astro.props
---

<article class:list={[
  'surface-card rounded-[1.75rem]',
  compact ? 'p-5' : 'p-6'
]}>
  <div class="flex flex-wrap gap-2">
    {project.stack.map((item) => (
      <span class="rounded-full border border-[var(--border-soft)] bg-[var(--surface-strong)] px-3 py-1 text-xs font-medium text-[var(--muted)]">{item}</span>
    ))}
  </div>
  <h3 class="mt-5 text-xl font-semibold text-[var(--foreground)]">{project.title}</h3>
  <p class="mt-3 text-sm leading-7 text-[var(--muted)]">{project.summary}</p>
  <p class="mt-4 border-t border-[var(--border-soft)] pt-4 text-sm font-medium text-[var(--accent-text)]">{project.outcome}</p>
</article>
