---
import RootLayout from '@/layouts/RootLayout.astro'
import { getPortfolioContent } from '@/features/portfolio/content'
import { parseLocale, parseTheme } from '@/lib/preferences'

export const prerender = false

const locale = parseLocale(Astro.url.searchParams.get('lang') ?? Astro.locals.locale)
const theme = parseTheme(Astro.url.searchParams.get('theme') ?? Astro.locals.theme)
const copy = getPortfolioContent(locale)
const autoprint = Astro.url.searchParams.get('autoprint') === '1'
const from = Astro.url.searchParams.get('from') || '/'
---

<RootLayout
  title={`${copy.meta.title} | PDF`}
  description={copy.pdf.routeLead}
  locale={locale}
  theme={theme}
  skipToContentLabel={copy.meta.skipToContent}
>
  {autoprint && (
    <script is:inline>
      window.addEventListener('load', () => {
        window.setTimeout(() => window.print(), 250)
      })
    </script>
  )}

  <main id="content" class="print-shell mx-auto max-w-4xl px-4 py-8 sm:px-6">
    <div class="screen-only mb-6 flex flex-wrap items-center gap-3">
      <a href={from} class="action-secondary">{copy.pdf.backToSite}</a>
      <button type="button" class="action-primary" onclick="window.print()">{copy.pdf.printAction}</button>
    </div>

    <header class="mb-8 border-b border-[var(--border-soft)] pb-6">
      <p class="eyebrow-token">{copy.hero.eyebrow}</p>
      <h1 class="mt-3 text-4xl font-semibold tracking-tight text-[var(--foreground)]">{copy.meta.title}</h1>
      <p class="mt-4 max-w-2xl text-base leading-7 text-[var(--muted)]">{copy.pdf.routeLead}</p>
      <p class="screen-only mt-3 text-sm text-[var(--subtle)]">{copy.pdf.helper}</p>
    </header>

    <section class="mb-8 space-y-4">
      <h2 class="text-2xl font-semibold text-[var(--foreground)]">{copy.hero.title}</h2>
      <p class="text-lg text-[var(--subtle)]">{copy.hero.highlight}</p>
      <p class="max-w-3xl text-sm leading-7 text-[var(--muted)]">{copy.hero.description}</p>
    </section>

    <section class="mb-8">
      <h2 class="mb-4 text-2xl font-semibold text-[var(--foreground)]">{copy.about.title}</h2>
      <div class="grid gap-4 sm:grid-cols-2">
        {copy.about.highlights.map((item) => (
          <article class="surface-card rounded-2xl p-5">
            <h3 class="text-base font-semibold text-[var(--foreground)]">{item.title}</h3>
            <p class="mt-2 text-sm leading-7 text-[var(--muted)]">{item.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="mb-8">
      <h2 class="mb-4 text-2xl font-semibold text-[var(--foreground)]">{copy.projects.title}</h2>
      <div class="grid gap-4">
        {copy.projects.items.map((project) => (
          <article class="surface-card rounded-2xl p-5">
            <div class="flex flex-wrap gap-2">
              {project.stack.map((item) => (
                <span class="rounded-full border border-[var(--border-soft)] px-3 py-1 text-xs font-medium text-[var(--muted)]">{item}</span>
              ))}
            </div>
            <h3 class="mt-4 text-lg font-semibold text-[var(--foreground)]">{project.title}</h3>
            <p class="mt-2 text-sm leading-7 text-[var(--muted)]">{project.summary}</p>
            <p class="mt-3 text-sm font-medium text-[var(--accent-text)]">{project.outcome}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="mb-8">
      <h2 class="mb-4 text-2xl font-semibold text-[var(--foreground)]">{copy.stack.title}</h2>
      <div class="grid gap-4 sm:grid-cols-2">
        {copy.stack.notes.map((note) => (
          <article class="surface-card rounded-2xl p-5">
            <h3 class="text-base font-semibold text-[var(--foreground)]">{note.title}</h3>
            <p class="mt-2 text-sm leading-7 text-[var(--muted)]">{note.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section>
      <h2 class="mb-4 text-2xl font-semibold text-[var(--foreground)]">{copy.contact.title}</h2>
      <article class="surface-card rounded-2xl p-5">
        <p class="text-subtle-token">{copy.contact.panelEyebrow}</p>
        <h3 class="mt-3 text-lg font-semibold text-[var(--foreground)]">{copy.contact.panelTitle}</h3>
        <p class="mt-2 text-sm leading-7 text-[var(--muted)]">{copy.contact.panelDescription}</p>
        <div class="mt-5 grid gap-2 text-sm">
          <a href="mailto:dario@example.com">{copy.contact.emailLabel}</a>
          <a href="https://github.com/" target="_blank" rel="noreferrer">{copy.contact.githubLabel}</a>
          <a href="https://www.linkedin.com/" target="_blank" rel="noreferrer">{copy.contact.linkedinLabel}</a>
        </div>
      </article>
    </section>
  </main>
</RootLayout>
