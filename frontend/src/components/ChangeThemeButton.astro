---
import SunIcon from "../../public/Icons/SunIcon.astro";
import MoonIcon from "../../public/Icons/MoonIcon.astro";
interface Props {
  title?: string;
  ariaLabel?: string;
  caption?: string;
}

const {
  title = "Change color theme",
  ariaLabel = "Toggle dark mode",
  caption = "Theme",
} = Astro.props as Props;
---

<label
  for="btnThemeDark"
  title={title}
  class="theme-toggle"
  aria-label={ariaLabel}
>
  <span class="theme-toggle__caption">{caption}</span>
  <input class="sr-only" id="btnThemeDark" type="checkbox" />
  <div
    id="tabPressTheme"
    tabindex="0"
    aria-label={ariaLabel}
    class="theme-toggle__track"
  >
    <span class="theme-toggle__text theme-toggle__text--light"><SunIcon /></span>
    <span class="theme-toggle__text theme-toggle__text--dark"><MoonIcon /></span>
    <span class="theme-toggle__thumb"></span>
  </div>
</label>

<script is:inline>
  const CheckBox = document.getElementById("btnThemeDark");
  const tabPressTheme = document.getElementById("tabPressTheme");

  if (
    !(CheckBox instanceof HTMLInputElement) ||
    !(tabPressTheme instanceof HTMLElement)
  ) {
    throw new Error("Theme toggle elements not found");
  }

  const CheckWatchMedia = () => {
    document.documentElement.classList.toggle(
      "dark",
      localStorage.theme === "dark" ||
        (!("theme" in localStorage) &&
          window.matchMedia("(prefers-color-scheme: dark)").matches),
    );
  };

  CheckWatchMedia();

  if (document.documentElement.classList.contains("dark")) {
    CheckBox.checked = true;
  }

  CheckBox.addEventListener("change", () => {
    if (CheckBox.checked) {
      document.documentElement.classList.add("dark");
      localStorage.theme = "dark";
    } else {
      document.documentElement.classList.remove("dark");
      localStorage.theme = "light";
    }
  });

  tabPressTheme.addEventListener("keydown", (event) => {
    if (event.key === "Enter" || event.key === " ") {
      event.preventDefault();
      CheckBox.click();
    }
  });
</script>
